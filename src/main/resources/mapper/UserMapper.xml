<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="team2.pjt12.matchumoney.domain.user.mapper.UserMapper">

    <select id="findBySocialIdAndSocialProvider" resultType="team2.pjt12.matchumoney.domain.user.domain.UserVO">
        SELECT *
        FROM users
        WHERE social_id = #{socialId}
          AND social_provider = #{socialProvider}
    </select>


    <select id="findByEmail" resultType="team2.pjt12.matchumoney.domain.user.domain.UserVO">
        SELECT *
        FROM users
        WHERE email = #{email}
    </select>

    <select id="existsByEmail" resultType="boolean">
        SELECT
            CASE WHEN COUNT(*) > 0 THEN TRUE ELSE FALSE END
        FROM users
        WHERE email = #{email}
    </select>

    <select id="findByUserId" resultType="team2.pjt12.matchumoney.domain.user.domain.UserVO">
        SELECT *
        FROM users
        WHERE user_id = #{userId}
    </select>

    <update id="updateUserInfo">
        UPDATE users
        SET nickname = #{nickname},
            gender = #{gender},
            birth_date = #{birthDate}
        WHERE user_id = #{userId}
    </update>

    <update id="updatePassword">
        UPDATE users
        SET password = #{newPassword}
        WHERE user_id = #{userId}
    </update>
</mapper>