<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="team2.pjt12.matchumoney.domain.depositdetail.mapper.DepositDetailMapper">

    <!-- deposit_option 매핑 -->
    <resultMap id="DepositOptionResultMap" type="team2.pjt12.matchumoney.domain.depositdetail.dto.DepositOptionDTO">
        <id property="depositOptionId" column="deposit_option_id" />
        <result property="intrRateType" column="intr_rate_type" />
        <result property="intrRateTypeNm" column="intr_rate_type_nm" />
        <result property="saveTrm" column="save_trm" />
        <result property="intrRate" column="intr_rate" />
        <result property="intrRate2" column="intr_rate2" />
        <result property="depositProductId" column="deposit_product_id" />
        <result property="finPrdtCd" column="fin_prdt_cd" />
        <result property="finId" column="fin_id" />
    </resultMap>

    <!-- deposit_product + deposit_option list 매핑 -->
    <resultMap id="DepositDetailResultMap" type="team2.pjt12.matchumoney.domain.depositdetail.dto.DepositDetailResponseDTO">
        <id property="depositProductId" column="deposit_product_id" />
        <result property="dclsMonth" column="dcls_month" />
        <result property="korCoNm" column="kor_co_nm" />
        <result property="finPrdtNm" column="fin_prdt_nm" />
        <result property="joinWay" column="join_way" />
        <result property="mtrtInt" column="mtrt_int" />
        <result property="spclCnd" column="spcl_cnd" />
        <result property="joinDeny" column="join_deny" />
        <result property="joinMember" column="join_member" />
        <result property="etcNote" column="etc_note" />
        <result property="maxLimit" column="max_limit" />
        <result property="dclsStrtDay" column="dcls_strt_day" />
        <result property="dclsEndDay" column="dcls_end_day" />
        <result property="finCoSubmDay" column="fin_co_subm_day" />
        <result property="productType" column="product_type" />
        <result property="finCoNo" column="fin_co_no" />
        <result property="finPrdtCd" column="fin_prdt_cd" />
        <result property="finId" column="fin_id" />
        <result property="personaId" column="persona_id" />

        <!-- 옵션 리스트 매핑 -->
        <collection property="options" ofType="team2.pjt12.matchumoney.domain.depositdetail.dto.DepositOptionDTO"
                    resultMap="DepositOptionResultMap" />
    </resultMap>

    <!-- 단건 조회 + 조인 -->
    <select id="findDepositProductById" resultMap="DepositDetailResultMap" parameterType="long">
        SELECT
            p.deposit_product_id, p.dcls_month, p.kor_co_nm, p.fin_prdt_nm,
            p.join_way, p.mtrt_int, p.spcl_cnd, p.join_deny,
            p.join_member, p.etc_note, p.max_limit, p.dcls_strt_day,
            p.dcls_end_day, p.fin_co_subm_day, p.product_type,
            p.fin_co_no, p.fin_prdt_cd, p.fin_id, p.persona_id,

            o.deposit_option_id, o.intr_rate_type, o.intr_rate_type_nm,
            o.save_trm, o.intr_rate, o.intr_rate2,
            o.deposit_product_id AS o_deposit_product_id,
            o.fin_prdt_cd AS o_fin_prdt_cd, o.fin_id AS o_fin_id

        FROM deposit_product p
                 LEFT JOIN deposit_option o ON p.deposit_product_id = o.deposit_product_id
        WHERE p.deposit_product_id = #{id}
    </select>

    <!-- 옵션만 따로 조회 -->
    <select id="findOptionsByProductId" resultMap="DepositOptionResultMap" parameterType="long">
        SELECT
            deposit_option_id, intr_rate_type, intr_rate_type_nm,
            save_trm, intr_rate, intr_rate2,
            deposit_product_id, fin_prdt_cd, fin_id
        FROM deposit_option
        WHERE deposit_product_id = #{productId}
    </select>

</mapper>